<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron needs these two under the hardened runtime so JIT and dyld work for V8.
       Without them the signed/notarized build can restrict JIT, degrading the JS that
       schedules Web Audio + MIDI timing. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Electron's helper processes load frameworks that aren't signed by us. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.inherit</key>
  <true/>
  <!-- Outbound HTTPS to the KCC backend (license check, sample library). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Future-proofing for RECORD-style features; harmless if unused. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
